# ===========================================
# Leadsens Environment Variables
# Copy to .env.local and fill in real values
# ===========================================

# Auth (Auth.js v5)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_URL=http://localhost:3000

# Google OAuth (Gmail + Calendar read access)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth / Entra (Outlook Mail + Graph Calendar) — optional
# but required for users who want to sign in with Microsoft.
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/leadsens

# LLM Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Sovereignty / GDPR Region Pinning (FINDING-004)
# Set ANTHROPIC_REGION=eu to route all Anthropic API calls through
# eu.anthropic.com instead of api.anthropic.com (US default).
# Alternatively, set ANTHROPIC_API_BASE to an explicit endpoint URL
# (must be in the allowlist: https://eu.anthropic.com or https://api.anthropic.com).
ANTHROPIC_REGION=eu
# ANTHROPIC_API_BASE=https://eu.anthropic.com

# GDPR_REGION=eu enables runtime validation that DATABASE_URL points to
# an EU host (Supabase eu-central-1, Neon eu-central-1/eu-west-1, Scaleway
# fr-par, OVH gra/sbg, Infomaniak ch-dk). The app logs a CRITICAL warning
# on startup if the host does not match a known EU/CH pattern.
GDPR_REGION=eu

# LLM provider router. "anthropic" (default), "mistral" (EU-sovereign), or
# "auto" (Mistral first, Anthropic EU fallback when MISTRAL_API_KEY unset).
# LLM_PROVIDER=anthropic
# MISTRAL_API_KEY=

# Sentry region: set SENTRY_DSN to *.de.sentry.io (Frankfurt) to keep
# error events in the EU. The default US DSN sends PII through US infra.
# SENTRY_DSN=https://<key>@<org>.de.sentry.io/<project>
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.de.sentry.io/<project>

# Apollo.io (enrichment + search)
APOLLO_API_KEY=your-apollo-api-key

# Datagma (EU company enrichment — $39/mo for 3,000 credits)
# Get your key at https://app.datagma.com/
DATAGMA_API_KEY=

# Firmable (Australia/NZ company enrichment — ANZ specialist)
# Get your key at https://docs.firmable.com/api-reference/
FIRMABLE_API_KEY=

# Hunter.io (email finding + verification — free tier: 50 searches/month)
HUNTER_API_KEY=

# Crunchbase Enterprise API (optional — funding data, investors)
# Only available on Enterprise plan. Adapter activates automatically when set.
CRUNCHBASE_API_KEY=

# Email (Resend)
RESEND_API_KEY=re_...
# Webhook signing secret from Resend → Webhooks → your endpoint.
# Unset in dev = no signature check. Set in prod to verify Svix
# signatures on POST /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=
# Verified sender shown on invite + follow-up emails. Must be a
# verified domain in Resend before going live.
INVITE_FROM_ADDRESS=Elevay <invites@resend.dev>

# EmailEngine (mail sync)
EMAILENGINE_URL=http://localhost:3100
EMAILENGINE_WEBHOOK_SECRET=your-emailengine-webhook-secret

# Public URL used to build absolute links in outbound email (tracking
# pixel, click redirect, unsubscribe, accept-invite). Defaults to
# https://app.elevay.com in code; override per-env.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Queue (Redis / Upstash)
REDIS_URL=redis://localhost:6379

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Recall.ai (meeting bot — auto-joins calls, records, transcribes)
RECALL_API_KEY=your-recall-api-key

# Stripe (billing) — required for paid plans.
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# WS-1 Guardrails — encryption secret for Instantly API keys and
# sensitive tenant settings. Generate with: openssl rand -hex 32
ELEVAY_APP_SECRET=generate-with-openssl-rand-hex-32

# WS-1 — email address for ops notifications (managed sending infra
# requests). Falls back to console log if unset.
OPS_EMAIL_ADDRESS=ops@yourdomain.com

# PostHog (product analytics) — unset disables event capture.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (observability) — unset disables error reporting.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_APP_ENV=development

# ─────────────────────────────────────────────────────────────
# Voice (Twilio + Deepgram) — required for /call-mode (cold call)
# See docs/voice-bootstrap.md for the step-by-step setup.
# ─────────────────────────────────────────────────────────────

# Twilio core — Account SID + Auth Token power the REST API client
# and the webhook-signature validator. Find both at
# https://console.twilio.com/ (Project Info card).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio API Key + Secret — used to sign the browser capability JWT
# (better than reusing the auth token because it can be revoked
# without rotating the whole account). Create at
# https://console.twilio.com/us1/account/keys-credentials/api-keys
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio TwiML App SID — wires the Voice SDK to our /api/calls/twiml
# webhook. Create at
# https://console.twilio.com/us1/develop/voice/manage/twiml-apps
TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio media region — keep on `ie1` (Dublin) for EU sovereignty,
# `us1` for US, `au1` for AU, `br1` for BR. Defaults to Twilio's
# default (global, no guarantee on residency) when unset.
TWILIO_REGION=ie1

# Deepgram (streaming transcription). Sign up at https://deepgram.com
# and create an API key with at minimum the "Member" role.
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Phone-number enrichment waterfall — Apollo is already configured
# elsewhere. Kaspr is the FR-mobile leader (€0.30/lookup, 55% mobile
# coverage in France). Lusha is the US/UK fallback.
KASPR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LUSHA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL Twilio uses to reach our webhooks. In production
# this is the workspace's elevay.* hostname. In development use ngrok
# (`ngrok http 3000`) and paste the https URL here — Twilio refuses
# http callbacks.
VOICE_PUBLIC_BASE_URL=https://your-tenant.elevay.ai

# Standalone Twilio Media Streams ↔ Deepgram bridge (Phase 1.5).
# Runs as a separate Node process via `pnpm voice:stream`. Twilio
# requires a wss:// URL — expose the bridge port through ngrok (a
# second tunnel: `ngrok http 3001`) and paste the wss URL here. In
# production, deploy the bridge on Fly.io / Railway / similar with TLS
# and use its public hostname.
VOICE_STREAM_PUBLIC_URL=wss://your-tunnel.ngrok-free.app
VOICE_STREAM_PORT=3001
# Set to 1 to log byte counts + Deepgram event traces from the bridge.
# VOICE_STREAM_DEBUG=1

# Recording-disclosure MP3 played at connect in two-party-consent
# regions (France + US states CA/IL/FL/PA/MA/MD/NV/NH/WA). 5-10s
# script per the legal team. Storage anywhere Twilio can fetch over
# HTTPS — S3, Supabase Storage, Cloudflare R2.
VOICE_DISCLOSURE_AUDIO_URL=https://your-cdn.example.com/voice/disclosure-fr.mp3

# Default voicemail MP3 used by Phase 2 drop-voicemail when no
# tenant-specific template is selected. 20-30s pre-recorded message.
# Phase 3 adds in-browser MediaRecorder authoring + a per-tenant
# library; until then this env is the single source of truth.
VOICE_VOICEMAIL_DEFAULT_URL=https://your-cdn.example.com/voice/voicemail-default-fr.mp3

# Phase 3 — live coaching switch. Set to "off" to disable the in-call
# objection classifier (Haiku 4.5) without touching the rest of the
# bridge. Defaults to ON when ANTHROPIC_API_KEY is set.
# VOICE_COACHING_LIVE=on
