# ===========================================
# Leadsens Environment Variables
# Copy to .env.local and fill in real values
# ===========================================

# Auth (Auth.js v5)
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_URL=http://localhost:3000

# Google OAuth (Gmail + Calendar read access)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth / Entra (Outlook Mail + Graph Calendar) — optional
# but required for users who want to sign in with Microsoft.
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/leadsens

# LLM Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Apollo.io (enrichment + search)
APOLLO_API_KEY=your-apollo-api-key

# Email (Resend)
RESEND_API_KEY=re_...
# Webhook signing secret from Resend → Webhooks → your endpoint.
# Unset in dev = no signature check. Set in prod to verify Svix
# signatures on POST /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=
# Verified sender shown on invite + follow-up emails. Must be a
# verified domain in Resend before going live.
INVITE_FROM_ADDRESS=Elevay <invites@resend.dev>

# EmailEngine (mail sync)
EMAILENGINE_URL=http://localhost:3100
EMAILENGINE_WEBHOOK_SECRET=your-emailengine-webhook-secret

# Public URL used to build absolute links in outbound email (tracking
# pixel, click redirect, unsubscribe, accept-invite). Defaults to
# https://app.elevay.com in code; override per-env.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Queue (Redis / Upstash)
REDIS_URL=redis://localhost:6379

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Recall.ai (meeting bot — auto-joins calls, records, transcribes)
RECALL_API_KEY=your-recall-api-key

# Stripe (billing) — required for paid plans.
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# Sentry (observability) — unset disables error reporting.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_APP_ENV=development
