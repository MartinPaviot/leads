{
  "name": "@leadsens/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "eval:run": "vitest run --reporter=verbose src/__tests__/chat-eval-suite.test.ts src/__tests__/golden-eval-gate.test.ts src/__tests__/inbox-reply-worthy-gate.test.ts src/__tests__/inbox-derive-style-gate.test.ts src/__tests__/inbox-splits-gate.test.ts src/__tests__/inbox-noise-gate.test.ts src/__tests__/inbox-ask-agent-gate.test.ts src/__tests__/inbox-refine-gate.test.ts src/__tests__/inbox-summary-gate.test.ts src/__tests__/inbox-draft-gate.test.ts src/__tests__/inbox-nudge-gate.test.ts src/__tests__/inbox-nofabrication-gate.test.ts src/__tests__/deal-signal-recall-gate.test.ts src/__tests__/deal-read-gate.test.ts",
