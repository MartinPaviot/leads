    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "echo '[ERROR] drizzle-kit journal stops at idx 12. Use db:migrate:apply (custom runner) instead.' && exit 1",
