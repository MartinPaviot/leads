# The Vercel build installs this self-contained web app with `npm install`
# (rootDirectory = app/apps/web). next-auth@5 (peerOptional nodemailer@7) and
# @auth/core (peerOptional nodemailer@6) declare conflicting optional peers, so
# once nodemailer is a real dependency (direct SMTP send) strict npm ERESOLVEs.
# Both peers are OPTIONAL; relaxing peer resolution is the correct, portable fix
# and keeps local + Vercel installs identical.
legacy-peer-deps=true
