# ── Local dev / verification scratch — never commit ──────────────────
# Throwaway verify + tally scripts (the `_`-prefix convention marks
# disposable dev artifacts), plus the session-minting helper.
_verify-*
app/apps/web/scripts/_*
app/apps/web/scripts/mint-session.mjs
_inngest-sink.mjs
# Internal audit notes + scratch backups.
_audit/
# Secrets minted for local verification (JWTs) — must never reach git.
_jwt*.txt
# Owner-SMTP provisioning credentials (real mailbox SMTP passwords) — never commit.
app/apps/web/scripts/.owner-smtp-creds.json
*.owner-smtp-creds.json
# Dev screenshot output + numbered root captures (NNN-name.png).
app/apps/web/screenshots/
/[0-9][0-9][0-9]-*.png

.vercel

# Supabase CLI scratch (linked-project state) — machine-local
supabase/.temp/

# ── Loose images at repo ROOT are always scratch/eval evidence — never ───
# commit them. Real product/brand images live under app/, docs/, orion/.
# This blanket rule supersedes the per-prefix whack-a-mole (OURS-*, inbox-*,
# callmode-*, batch*, leadsens-*, clerk-*, showcase-*, ui-*, ...) that kept
# letting each new screenshot batch slip into git history.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
# Heavy competitor-capture + merge-prep scratch (raw HTML/PNG/network dumps —
# kept locally as evidence, far too large to belong in git history).
/_research/upstream/
/_research/raw/pr277-merge-prep/

# ── Research / audit / eval evidence IMAGES ──────────────────────────────
# Screenshots, teardown frames and captured pages under the _*-process dirs
# (research, audit, reports, specs, fixtures, artifacts, ...) are kept ON DISK
# as local evidence but never tracked — they added ~137 MB of PNGs to git.
# Non-image docs (.md/.json/.html) in these dirs STAY tracked.
_*/**/*.png
_*/**/*.jpg
_*/**/*.jpeg
_*/**/*.gif
_*/**/*.webp
