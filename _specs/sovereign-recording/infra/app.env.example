# Env vars to set on the Elevay app (Vercel, production).
# Copy the JIBRI_WEBHOOK_SECRET that setup.sh prints — do NOT commit a real one.

# --- Sovereign booking (Part A) ---
VIDEO_MEET_BASE_URL=https://visio.pilae.ch

# --- Sovereign recording (Part B) ---
SOVEREIGN_RECORDING_ENABLED=true
JIBRI_WEBHOOK_SECRET=__paste_the_value_setup.sh_printed__
WHISPER_BASE_URL=https://whisper.pilae.ch/v1
# Optional: a specific self-hosted model
# WHISPER_MODEL=Systran/faster-whisper-large-v3

# Sovereignty level "Total" (optional): also move the intel LLM to an EU model
# by pointing lib/ai/ai-provider at Mistral — config there, not here.
